# Ghana Legal AI - Environment Variables
# Copy this file to .env and fill in your values

# Groq API for LLM inference
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API (for embeddings/evaluation)
OPENAI_API_KEY=your_openai_api_key_here

# Comet/Opik for tracing
COMET_API_KEY=your_comet_api_key_here
COMET_PROJECT=ghana_legal_course

# MongoDB connection
MONGO_URI=mongodb://ghana_legal:ghana_legal@localhost:27017/?directConnection=true

# LFM2/Ollama Configuration (for local model inference)
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ghana-legal

# --- SaaS Configuration ---

# Clerk Authentication
CLERK_ISSUER_URL=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev

# Paystack Billing
PAYSTACK_SECRET_KEY=sk_test_YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_WEBHOOK_SECRET=whsec_YOUR_PAYSTACK_WEBHOOK_SECRET

# Qdrant Cloud Vector Database
QDRANT_URL=https://YOUR_CLUSTER_ID.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=YOUR_QDRANT_API_KEY

# Sentry Error Tracking
SENTRY_DSN=
